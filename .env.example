# ============================================================
# Luvv MCPServer 环境变量（可选）
# 重命名此文件为 .env 后按需修改
# ============================================================

# semgrep 规则集（默认 auto，可选 "p/security-audit"、"p/owasp-top-ten" 等）
# 参考: https://semgrep.dev/explore
SEMGREP_CONFIG=auto

# semgrep 超时时间（秒），超过此时间强制终止扫描
SEMGREP_TIMEOUT=300

# gitleaks 超时时间（秒）
GITLEAKS_TIMEOUT=120

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 是否在结果中附带原始工具输出（true=完整输出, false=仅摘要）
INCLUDE_RAW_OUTPUT=false
